# ============================================
# DATABASE Configuration
# ============================================
DATABASE_URL=postgresql://username:password@localhost:5432/runestate_db

# ============================================
# JWT Configuration
# ============================================
# Secret key for JWT token encoding/decoding (generate with: openssl rand -hex 32)
SECRET_KEY=your-super-secret-key-change-this-in-production

# JWT token expiration time (in days)
JWT_EXPIRATION_DAYS=30

# ============================================
# Server Configuration
# ============================================
ENVIRONMENT=development
DEBUG=True

# ============================================
# CORS Configuration (Frontend URL)
# ============================================
FRONTEND_URL=http://localhost:3000

# ============================================
# AWS / File Upload Configuration
# ============================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your_s3_bucket_name
AWS_REGION=us-east-1

# ============================================
# OTP Configuration (Twilio for SMS)
# ============================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# OpenAI / AI Configuration
# ============================================
OPENAI_API_KEY=your_openai_api_key

# ============================================
# Email Configuration (SMTP)
# ============================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
